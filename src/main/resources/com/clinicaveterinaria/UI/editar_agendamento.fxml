<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.clinicaveterinaria.UI.EditarAgendamentoController">
    <children>
        <VBox layoutX="14.0" layoutY="14.0" prefHeight="672.0" prefWidth="872.0" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="14.0" AnchorPane.rightAnchor="14.0" AnchorPane.topAnchor="14.0">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="200.0" spacing="550.0">
                    <children>
                        <Label text="Editar Agendamento">
                            <font>
                                <Font name="System Bold" size="20.0" />
                            </font>
                        </Label>
                        <Button fx:id="voltarButton" mnemonicParsing="false" onAction="#handleVoltar" text="Voltar" />
                    </children>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </HBox>
                <ScrollPane VBox.vgrow="ALWAYS">
                    <content>
                        <VBox prefWidth="850.0" spacing="20.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="ID do Agendamento:" />
                                        <Label fx:id="lblAgendamentoId" text="[ID]" style="-fx-font-weight: bold;" />
                                    </children>
                                </HBox>
                                <Label text="Cliente" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <TextField fx:id="txtClienteSearch" prefWidth="300.0" promptText="CPF do cliente" />
                                        <Button fx:id="btnBuscarCliente" text="Buscar" onAction="#handleBuscarCliente" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="20.0">
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Nome:" />
                                                <TextField fx:id="txtClienteNome" editable="false" prefWidth="200.0" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Telefone:" />
                                                <TextField fx:id="txtClienteTelefone" editable="false" prefWidth="150.0" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Email:" />
                                                <TextField fx:id="txtClienteEmail" editable="false" prefWidth="200.0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label text="Animal" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <ComboBox fx:id="cmbAnimal" prefWidth="300.0" promptText="Selecione o animal" onAction="#handleAnimalSelecionado" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="20.0">
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Nome:" />
                                                <TextField fx:id="txtAnimalNome" editable="false" prefWidth="150.0" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Espécie:" />
                                                <TextField fx:id="txtAnimalEspecie" editable="false" prefWidth="100.0" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Raça:" />
                                                <TextField fx:id="txtAnimalRaca" editable="false" prefWidth="150.0" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Idade:" />
                                                <TextField fx:id="txtAnimalIdade" editable="false" prefWidth="80.0" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label text="Detalhes do Agendamento" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <HBox alignment="CENTER_LEFT" spacing="20.0">
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Data:" />
                                                <DatePicker fx:id="datePicker" prefWidth="150.0" onAction="#handleDataSelecionada" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Horário:" />
                                                <ComboBox fx:id="cmbHorario" prefWidth="120.0" onAction="#handleHorarioSelecionado" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Veterinário:" />
                                                <ComboBox fx:id="cmbVeterinario" prefWidth="200.0" onAction="#handleVeterinarioSelecionado" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Tipo de Procedimento:" />
                                        <ComboBox fx:id="cmbTipoProcedimento" prefWidth="300.0" onAction="#handleTipoProcedimentoSelecionado" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Observações:" />
                                        <TextArea fx:id="txtObservacoes" prefRowCount="3" promptText="Descreva o motivo da consulta ou observações importantes..." wrapText="true" />
                                    </children>
                                </VBox>

                                <Label text="Status" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                                <HBox alignment="CENTER_LEFT" spacing="20.0">
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Status do Agendamento:" />
                                                <ComboBox fx:id="cmbStatus" prefWidth="150.0" onAction="#handleStatusSelecionado" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="Prioridade:" />
                                                <ComboBox fx:id="cmbPrioridade" prefWidth="120.0" onAction="#handlePrioridadeSelecionada" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <Label fx:id="statusMessageLabel" textFill="RED" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
                <HBox alignment="CENTER_RIGHT" prefHeight="40.0" prefWidth="200.0" spacing="10.0">
                    <children>
                        <Button fx:id="cancelarEdicaoButton" mnemonicParsing="false" onAction="#handleCancelarEdicao" text="Cancelar" />
                        <Button fx:id="salvarEdicaoButton" mnemonicParsing="false" onAction="#handleSalvarEdicao" text="Salvar Edição" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>