<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.clinicaveterinaria.UI.CadastroPrincipalController">
   <VBox alignment="CENTER" layoutY="53.0" prefHeight="63.0" prefWidth="900.0">
      <Label text="CRIAR NOVA">
         <font>
            <Font name="Arial Black" size="20.0" />
         </font>
      </Label>
      <Label prefHeight="29.0" prefWidth="80.0" text="CONTA">
         <font>
            <Font name="Arial Black" size="20.0" />
         </font>
      </Label>
   </VBox>
   <VBox alignment="CENTER_LEFT" layoutX="250.0" layoutY="110.0" maxWidth="-Infinity" prefWidth="400.0" spacing="8.0" AnchorPane.leftAnchor="250.0" AnchorPane.rightAnchor="250.0" AnchorPane.topAnchor="110.0">
      <Label text="NOME:">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <TextField fx:id="nomeField" maxWidth="-Infinity" prefWidth="300.0" promptText="Nome" />

      <Label text="SOBRENOME:">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <TextField fx:id="sobrenomeField" maxWidth="-Infinity" prefWidth="300.0" promptText="Sobrenome">
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
      </TextField>
      <Label text="CRMV:">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <TextField fx:id="crmvField" maxWidth="-Infinity" prefWidth="300.0" promptText="XX 00000">
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
      </TextField>
      <Label text="TELEFONE:">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <TextField fx:id="telefoneField" maxWidth="-Infinity" prefWidth="300.0" promptText="(00) 0000-0000" />
      <Label text="EMAIL:">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <TextField fx:id="emailField" maxWidth="-Infinity" prefWidth="300.0" promptText="Email" />
      <Label text="SENHA:">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <PasswordField fx:id="senhaField" maxWidth="-Infinity" prefHeight="25.0" prefWidth="300.0" promptText="•••••••••" />
      <Label text="ESPECIALIDADE:">
         <font>
            <Font size="11.0" />
         </font>
      </Label>
      <TextField fx:id="especialidadeField" maxWidth="-Infinity" prefWidth="300.0" promptText="Especialidade" />
      <Label fx:id="errorLabel" prefHeight="17.0" prefWidth="163.0" textFill="RED" visible="false">
         <font>
            <Font size="10.0" />
         </font>
      </Label>
      <Label fx:id="successLabel" prefHeight="17.0" prefWidth="163.0" textFill="GREEN" visible="false">
         <font>
            <Font size="10.0" />
         </font>
      </Label>
      <padding>
         <Insets bottom="20.0" left="50.0" right="50.0" top="20.0" />
      </padding>
   </VBox>
   <VBox alignment="CENTER" layoutX="370.0" layoutY="571.0" prefHeight="81.0" prefWidth="142.0" spacing="5.0">
      <children>
         <Button mnemonicParsing="false" onAction="#criarConta" prefWidth="150.0" style="-fx-background-color: #000000;" text="CRIAR CONTA" textFill="WHITE">
            <font>
               <Font name="System Bold" size="12.0" />
            </font>
         </Button>
         <Label text="Já possui uma conta?">
            <font>
               <Font size="13.0" />
            </font>
         </Label>
         <Hyperlink onAction="#voltarLogin" text="Entrar">
            <font>
               <Font size="13.0" />
            </font>
         </Hyperlink>
      </children>
   </VBox>

</AnchorPane>
